---
import PortalLayout from '../layouts/PortalLayout.astro';
---

<PortalLayout title="التقارير — المالية الجامعية" active="reports">
  <div class="head no-print">
    <div>
      <h1 class="page-title">التقارير</h1>
      <p class="page-subtitle">تقارير الإيرادات حسب الفترة، مع التصدير والطباعة.</p>
    </div>
  </div>

  <!-- ===== Controls ===== -->
  <div class="card card-pad controls no-print">
    <div class="ctl-row">
      <div class="seg" role="group" aria-label="فترات سريعة">
        <button class="seg-btn active" type="button" data-range="daily">اليوم</button>
        <button class="seg-btn" type="button" data-range="weekly">آخر 7 أيام</button>
        <button class="seg-btn" type="button" data-range="monthly">آخر 30 يومًا</button>
      </div>

      <div class="custom">
        <div class="field">
          <label class="field-label" for="from">من</label>
          <input class="input" id="from" type="date" />
        </div>
        <div class="field">
          <label class="field-label" for="to">إلى</label>
          <input class="input" id="to" type="date" />
        </div>
        <button class="btn btn-primary" id="gen-btn" type="button">عرض</button>
      </div>
    </div>
    <div id="ctl-error" class="alert alert-danger hidden" role="alert"></div>
  </div>

  <!-- ===== States ===== -->
  <div id="rp-loading" class="state row"><span class="spinner"></span><span class="muted">جارٍ التحميل…</span></div>
  <div id="rp-empty" class="state muted hidden">لا توجد مدفوعات في هذه الفترة.</div>
  <div id="rp-error" class="state text-danger hidden"></div>

  <!-- ===== Result ===== -->
  <div id="rp-result" class="hidden stack">
    <!-- summary + export -->
    <div class="card card-pad result-head">
      <div class="rh-info">
        <h2 class="card-title" id="rp-title">—</h2>
        <p class="muted small" id="rp-sub"></p>
      </div>
      <div class="rh-totals">
        <div class="kpi">
          <span class="kpi-label">عدد الإيصالات</span>
          <strong class="kpi-value tabular" id="rp-count">0</strong>
        </div>
        <div class="kpi">
          <span class="kpi-label">إجمالي الإيرادات</span>
          <strong class="kpi-value tabular accent" id="rp-total">—</strong>
        </div>
      </div>
      <div class="rh-actions no-print">
        <button class="btn btn-outline btn-sm" id="csv-btn" type="button">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3" /></svg>
          تصدير CSV
        </button>
        <button class="btn btn-outline btn-sm" id="print-btn" type="button">
          <svg viewBox="0 0 24 24" width="15" height="15" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2M6 14h12v8H6z" /></svg>
          طباعة
        </button>
      </div>
    </div>

    <!-- table -->
    <div class="card list-card">
      <table class="table">
        <thead>
          <tr>
            <th>رقم الإيصال</th>
            <th>الطالب</th>
            <th>الرقم الجامعي</th>
            <th>الفصل</th>
            <th>طريقة الدفع</th>
            <th>الموظف</th>
            <th>التاريخ</th>
            <th class="num">المبلغ</th>
          </tr>
        </thead>
        <tbody id="rp-body"></tbody>
        <tfoot>
          <tr>
            <td colspan="7" class="ft-label">الإجمالي</td>
            <td class="num tabular" id="rp-foot-total">—</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <script>
    // @ts-nocheck — plain JS (DOM), not type-checked
    import { requireAuth } from '../lib/auth.js';
    import { getConfig } from '../lib/config.js';
    import { formatMoney, formatDate, formatDateTime } from '../lib/format.js';
    import { getReport } from '../lib/api/endpoints.js';

    if (requireAuth('manager')) {
      let currency = 'LYD';
      let lastReport = null; // keep the latest report for CSV export

      const $ = (s) => document.getElementById(s);
      const esc = (v) => String(v ?? '').replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));

      const loading = $('rp-loading');
      const empty = $('rp-empty');
      const errorBox = $('rp-error');
      const result = $('rp-result');
      const ctlError = $('ctl-error');

      function setBusy(on) {
        if (on) {
          loading.classList.remove('hidden');
          empty.classList.add('hidden');
          errorBox.classList.add('hidden');
        } else {
          loading.classList.add('hidden');
        }
      }

      function render(report) {
        lastReport = report;
        const rangeText = report.from && report.to && report.from !== report.to
          ? `${formatDate(report.from)} — ${formatDate(report.to)}`
          : formatDate(report.from || report.to);

        $('rp-title').textContent = `تقرير ${report.range_label}`;
        $('rp-sub').textContent = rangeText;
        $('rp-count').textContent = report.count;
        $('rp-total').textContent = formatMoney(report.total, currency);
        $('rp-foot-total').textContent = formatMoney(report.total, currency);

        if (!report.rows.length) {
          result.classList.add('hidden');
          empty.classList.remove('hidden');
          return;
        }
        empty.classList.add('hidden');
        $('rp-body').innerHTML = report.rows.map((r) => `<tr>
          <td class="tabular">#${esc(r.receipt_no)}</td>
          <td><strong>${esc(r.student_name)}</strong></td>
          <td class="tabular">${esc(r.university_id)}</td>
          <td>${esc(r.semester)}</td>
          <td>${esc(r.payment_method)}</td>
          <td>${esc(r.employee_name)}</td>
          <td class="nowrap">${esc(formatDateTime(r.timestamp))}</td>
          <td class="num tabular">${formatMoney(r.amount, currency)}</td>
        </tr>`).join('');
        result.classList.remove('hidden');
      }

      async function run(range, params = {}) {
        ctlError.classList.add('hidden');
        setBusy(true);
        result.classList.add('hidden');
        try {
          const report = await getReport(range, params);
          setBusy(false);
          render(report);
        } catch (err) {
          setBusy(false);
          errorBox.textContent = err?.message || 'تعذّر إنشاء التقرير.';
          errorBox.classList.remove('hidden');
        }
      }

      // ---------- quick ranges ----------
      document.querySelectorAll('.seg-btn').forEach((btn) => {
        btn.addEventListener('click', () => {
          document.querySelectorAll('.seg-btn').forEach((b) => b.classList.toggle('active', b === btn));
          $('from').value = '';
          $('to').value = '';
          run(btn.dataset.range);
        });
      });

      // ---------- custom range ----------
      $('gen-btn').addEventListener('click', () => {
        const from = $('from').value;
        const to = $('to').value;
        if (!from || !to) { ctlError.textContent = 'يرجى تحديد تاريخي البداية والنهاية.'; ctlError.classList.remove('hidden'); return; }
        if (to < from) { ctlError.textContent = 'تاريخ النهاية يجب ألا يسبق تاريخ البداية.'; ctlError.classList.remove('hidden'); return; }
        document.querySelectorAll('.seg-btn').forEach((b) => b.classList.remove('active'));
        run('custom', { from, to });
      });

      // ---------- CSV export ----------
      $('csv-btn').addEventListener('click', () => {
        if (!lastReport || !lastReport.rows.length) return;
        const cell = (v) => `"${String(v ?? '').replace(/"/g, '""')}"`;
        const headers = ['رقم الإيصال', 'الطالب', 'الرقم الجامعي', 'الفصل', 'طريقة الدفع', 'الموظف', 'التاريخ', 'المبلغ'];
        const lines = [headers.map(cell).join(',')];
        for (const r of lastReport.rows) {
          lines.push([r.receipt_no, r.student_name, r.university_id, r.semester, r.payment_method, r.employee_name, formatDateTime(r.timestamp), r.amount].map(cell).join(','));
        }
        lines.push([''].map(cell).join(','));
        lines.push([cell('الإجمالي'), '', '', '', '', '', '', cell(lastReport.total)].join(','));

        // BOM so Excel reads UTF-8 Arabic correctly.
        const blob = new Blob(['﻿' + lines.join('\r\n')], { type: 'text/csv;charset=utf-8;' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        const stamp = (lastReport.from || '') + (lastReport.to && lastReport.to !== lastReport.from ? `_${lastReport.to}` : '');
        a.href = url;
        a.download = `report_${stamp || 'all'}.csv`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
      });

      // ---------- print ----------
      $('print-btn').addEventListener('click', () => window.print());

      // ---------- init ----------
      (async () => {
        currency = (await getConfig()).currency;
        run('daily');
      })();
    }
  </script>

  <style>
    .head { margin-block-end: var(--space-5); }

    .controls { margin-block-end: var(--space-5); }
    .ctl-row { display: flex; align-items: flex-end; justify-content: space-between; gap: var(--space-5); flex-wrap: wrap; }

    .seg { display: inline-flex; border: 1px solid var(--color-border-strong); border-radius: var(--radius-sm); overflow: hidden; }
    .seg-btn {
      padding: 9px 16px; border: none; background: var(--color-surface); color: var(--color-muted);
      font-weight: 600; font-size: 0.9rem; cursor: pointer; white-space: nowrap;
      border-inline-start: 1px solid var(--color-border);
    }
    .seg-btn:first-child { border-inline-start: none; }
    .seg-btn:hover { background: var(--color-surface-2); }
    .seg-btn.active { background: var(--color-primary); color: var(--color-primary-contrast); }

    .custom { display: flex; align-items: flex-end; gap: var(--space-3); flex-wrap: wrap; }
    .custom .field { gap: 4px; }
    .custom .input { width: auto; }

    .state { margin-block-start: var(--space-4); }

    .result-head { display: flex; align-items: center; justify-content: space-between; gap: var(--space-5); flex-wrap: wrap; }
    .rh-totals { display: flex; gap: var(--space-6); }
    .kpi { display: flex; flex-direction: column; gap: 2px; }
    .kpi-label { font-size: 0.8rem; color: var(--color-muted); }
    .kpi-value { font-size: 1.4rem; }
    .kpi-value.accent { color: var(--color-success-text); }
    .rh-actions { display: flex; gap: var(--space-2); }

    .list-card { overflow: hidden; }
    .table tfoot td { font-weight: 700; border-block-start: 2px solid var(--color-border-strong); border-block-end: none; background: var(--color-surface-2); }
    .ft-label { text-align: start; color: var(--color-muted); }

    @media (max-width: 720px) {
      .ctl-row { flex-direction: column; align-items: stretch; }
      .seg { width: 100%; }
      .seg-btn { flex: 1; }
    }

    /* Print: drop the chrome, let the result fill the page. */
    @media print {
      .result-head { box-shadow: none; border: none; padding: 0 0 var(--space-3); }
      .list-card { box-shadow: none; border: 1px solid var(--color-border); }
      .rh-totals { gap: var(--space-5); }
    }
  </style>
</PortalLayout>
