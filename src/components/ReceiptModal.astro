---
import ReceiptView from './ReceiptView.astro';
---

<div id="receipt-modal" class="modal-overlay hidden" aria-hidden="true">
  <div class="modal-card" role="dialog" aria-modal="true">
    <button class="modal-close no-print" id="rcp-close" type="button" aria-label="إغلاق">✕</button>
    <ReceiptView />
    <div class="modal-actions no-print">
      <button class="btn btn-primary" type="button" id="rcp-print">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9V2h12v7" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><path d="M6 14h12v8H6z" /></svg>
        طباعة الإيصال
      </button>
      <button class="btn btn-outline" type="button" id="rcp-done">تم</button>
    </div>
  </div>
</div>

<script>
  // @ts-nocheck — plain JS (DOM), not type-checked
  import { closeReceiptModal, printReceipt } from '../lib/receipt.js';

  const modal = document.getElementById('receipt-modal');
  document.getElementById('rcp-close')?.addEventListener('click', closeReceiptModal);
  document.getElementById('rcp-done')?.addEventListener('click', closeReceiptModal);
  document.getElementById('rcp-print')?.addEventListener('click', printReceipt);
  modal?.addEventListener('click', (e) => { if (e.target === modal) closeReceiptModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeReceiptModal(); });
</script>

<style>
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(15, 23, 42, 0.55);
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: var(--space-6) var(--space-4);
    overflow-y: auto;
    z-index: 100;
  }
  .modal-card { position: relative; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); }
  .modal-close {
    position: absolute;
    inset-inline-end: -6px;
    inset-block-start: -42px;
    width: 34px; height: 34px;
    border-radius: 50%;
    border: none;
    background: #fff;
    color: var(--color-heading);
    font-size: 1rem;
    cursor: pointer;
    box-shadow: var(--shadow);
  }
  .modal-actions { display: flex; gap: var(--space-3); }
</style>
