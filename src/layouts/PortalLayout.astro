---
import BaseLayout from './BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import Topbar from '../components/Topbar.astro';

// active: nav key; title: page <title>
const { title = 'المالية الجامعية', active = '' } = Astro.props;
---

<BaseLayout title={title}>
  <div class="app-shell" data-auth-pending>
    <Sidebar active={active} />
    <div class="main">
      <Topbar />
      <main class="content">
        <slot />
      </main>
    </div>
  </div>

  <script>
    import { requireAuth, getCurrentUser } from '../lib/auth.js';

    const ROLE_RANK = { employee: 1, manager: 2, superadmin: 3 };

    // UX guard only — the backend enforces real auth/roles on every request.
    if (requireAuth()) {
      const user = getCurrentUser();
      const rank = ROLE_RANK[user?.role] || 0;
      // Remove nav/actions the current role may not use.
      document.querySelectorAll('[data-role-min]').forEach((el) => {
        const min = ROLE_RANK[el.getAttribute('data-role-min')] || 0;
        if (rank < min) el.remove();
      });
      document.querySelector('.app-shell')?.removeAttribute('data-auth-pending');
    }
  </script>

  <style>
    .app-shell { display: flex; min-height: 100vh; }
    .app-shell[data-auth-pending] { opacity: 0; }
    .main { flex: 1; display: flex; flex-direction: column; min-width: 0; }
    .content {
      width: 100%;
      max-width: var(--content-max);
      margin-inline: auto;
      padding: var(--space-6);
    }
    @media (max-width: 820px) {
      .app-shell { flex-direction: column; }
    }
    @media print {
      .app-shell { display: block; opacity: 1 !important; }
      .main { display: block; }
      .content { max-width: none; padding: 0; }
    }
  </style>
</BaseLayout>
